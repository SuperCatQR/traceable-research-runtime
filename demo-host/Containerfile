FROM docker.io/library/node:22-bookworm-slim AS frontend
WORKDIR /workspace/demo
COPY demo/package.json demo/package-lock.json ./
RUN npm ci
COPY demo ./
RUN npm run build

FROM docker.io/library/rust:1.96-bookworm AS builder
WORKDIR /workspace
COPY Cargo.toml Cargo.lock ./
COPY src ./src
COPY demo-host ./demo-host
COPY docs/database ./docs/database
RUN cargo build --release --manifest-path demo-host/Cargo.toml

FROM docker.io/library/debian:bookworm-slim
RUN apt-get update \
 && apt-get install -y --no-install-recommends ca-certificates \
 && rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY --from=builder /workspace/demo-host/target/release/traceable-search-demo-host /usr/local/bin/demo-host
COPY --from=frontend /workspace/demo/dist ./static
ENV DEMO_STATIC_DIR=/app/static \
    DEMO_BIND=127.0.0.1:8080 \
    TRACEABLE_SEARCH_DATA_DIR=/data
EXPOSE 8080
ENTRYPOINT ["/usr/local/bin/demo-host"]
