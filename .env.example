# Runtime dependencies
BRAVE_SEARCH_API_KEY=

# OpenAI-compatible gateway; verified with New API v1.0.0-rc.21
STRONG_MODEL_BASE_URL=http://127.0.0.1:3000/v1/
STRONG_MODEL_API_KEY=
STRONG_MODEL_ID=

# Local snapshot, intake history, and research trace output
TRACEABLE_SEARCH_DATA_DIR=./data

# Demo Host account catalogue and credential encryption.
# Generate and persist a base64-encoded 32-byte key outside the repository.
DEMO_CREDENTIAL_ENCRYPTION_KEY=
DEMO_CATALOG_PATH=
DEMO_HOST_PORT=8080
DEMO_MAX_CONCURRENT_RESEARCH=2
DEMO_SECURE_COOKIES=false
DEMO_ALLOW_PRIVATE_MODEL_ENDPOINTS=false
DEMO_TRUSTED_HOSTS=localhost,127.0.0.1
DEMO_TRUSTED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Vite development proxy. Production uses same-origin /api from Demo Host.
VITE_API_PROXY_TARGET=http://127.0.0.1:8080
