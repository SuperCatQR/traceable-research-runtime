  "content": {
    "user_title": "Build Production-Ready MCP Servers",
    "value_statement": "MCP server projects can become hard to secure, test, and maintain. This skill guides Claude, Codex, and Claude Code through architecture, security, performance, testing, and operations patterns.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "MCP server best practices",
      "Rust MCP server",
      "MCP security",
      "MCP testing",
      "MCP architecture",
      "MCP observability",
      "production MCP"
    ],
    "actual_capabilities": [
      "Explains layered, hexagonal, and repository architecture patterns for MCP services.",
      "Provides Rust examples for error types, retries, and validation.",
      "Shows authentication, authorization, and SQL injection prevention patterns.",
      "Covers connection pooling, caching, concurrent async work, and timeouts.",
      "Describes unit tests, integration tests, logging, metrics, and configuration management."
    ],
    "limitations": [
      "Provides guidance only; it does not generate or run a complete server by itself.",
      "Examples focus on Rust and rmcp-style services, not every MCP framework.",
      "Security advice is illustrative and must be adapted to each deployment.",
      "It does not replace code review, threat modeling, or production monitoring."
    ],
    "use_cases": [
      {
        "title": "Design a New MCP Server",
        "description": "Plan service layers, domain boundaries, repositories, and adapters before implementation.",
        "target_user": "MCP developers"
      },
      {
        "title": "Review Security Controls",
        "description": "Check validation, authentication, authorization, and database query patterns in an existing MCP service.",
        "target_user": "Security reviewers"
      },
      {
        "title": "Prepare Production Operations",
        "description": "Add tests, metrics, structured logs, configuration loading, and maintenance checklists before launch.",
        "target_user": "Platform engineers"
      }
    ],
    "prompt_templates": [
      {
        "title": "Review My MCP Design",
        "scenario": "Beginner review of a planned MCP server.",
        "prompt": "Review my MCP server design for architecture, security, testing, and operations. Ask for missing details before giving recommendations."
      },
      {
        "title": "Improve Error Handling",
        "scenario": "Intermediate review of service errors and retries.",
        "prompt": "Review my MCP error handling strategy. Check error types, retry behavior, user-facing messages, and recovery paths."
      },
      {
        "title": "Audit Security Patterns",
        "scenario": "Advanced security review for implemented tools.",
        "prompt": "Check this MCP service for validation, authentication, authorization, SQL safety, secret handling, and audit gaps. List the highest risks first."
      },
      {
        "title": "Create a Launch Checklist",
        "scenario": "Advanced production readiness planning.",
        "prompt": "Create a production readiness checklist for my MCP server. Include architecture, security, tests, observability, configuration, deployment, and maintenance."
      }
    ],
    "output_examples": [
      {
        "input": "Review a planned Rust MCP server that stores users in Postgres and exposes admin tools.",
        "output": [
          "Separate transport, service, domain, and infrastructure layers.",
          "Require authentication before admin actions and keep authorization checks near tool handlers.",
          "Use parameterized database queries, validation, and integration tests with isolated test data."
        ]
      },
      {
        "input": "Improve reliability for an MCP tool that calls an external API.",
        "output": [
          "Add timeouts, bounded retries, and retryable error classifications.",
          "Use caching only for data that can tolerate stale results.",
          "Track request counts, duration, and errors with structured metrics."
        ]
      },
      {
        "input": "Prepare an MCP server for release after the first working prototype.",
        "output": [
          "Add unit tests, integration tests, and deployment configuration checks.",
          "Document operational runbooks, health checks, and ownership boundaries.",
          "Review dependency health, audit logging, and graceful shutdown behavior."
        ]
      }
    ],
    "best_practices": [
      "Validate every tool input and map errors to clear, stable error types.",
      "Keep MCP transport code separate from domain logic and external adapters.",
      "Test security, database, and external service behavior before production release."
    ],
    "anti_patterns": [
      "Building business logic directly inside transport handlers.",
      "Using string concatenation for database queries.",
      "Adding logs and metrics after incidents instead of during development."
    ],
    "faq": [
      {
        "question": "What does this skill help with?",
        "answer": "It helps review and design production MCP servers with Rust-focused patterns for architecture, security, testing, and operations."
      },
      {
        "question": "Is this only for Rust?",
        "answer": "The examples use Rust, but many architecture and security practices apply to other MCP server implementations."
      },
      {
        "question": "Does it create a complete MCP server?",
        "answer": "No. It provides guidance, review prompts, examples, and checklists for developers building their own server."
      },
      {
        "question": "Can it replace security review?",
        "answer": "No. Use it as a checklist and design aid, then run threat modeling, code review, and deployment-specific testing."
      },
      {
        "question": "Which tools are supported?",
        "answer": "The skill is intended for Claude, Codex, and Claude Code workflows."
      },
